// Inspect output columns and reuse them in compile-time map expansion.

let quotes = Table {
    symbol = ["A", "B"],
    price  = [10.0, 20.0],
    qty    = [2.0, 4.0]
};

print("the quotes table:");
print(quotes);

print("its column names (a compile-time list):");
columns(quotes);

let cols = columns(quotes);

print("duplicate every column as copy_<name> via a map over that list:");
quotes[update {
    map c in cols => `copy_${c}` = get(c)
}];
