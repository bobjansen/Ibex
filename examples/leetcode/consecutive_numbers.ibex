import "csv";

let logs =
    read_csv("examples/leetcode/data/logs.csv",
             schema = "id:int,num:str");

let n = 1;

// LeetCode 180: Consecutive Numbers.
//
// Translation pattern:
// 1. Compare each row with the previous two rows using lag directly in filter.
// 2. Deduplicate matching numbers.

let result =
    logs[
        filter num == lag(num, n) && num == lag(num, n + 1)
    ][
        distinct { ConsecutiveNums = num }
    ];

result;
