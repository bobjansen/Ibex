// 1BRC-style aggregation over the raw headerless semicolon-delimited file.
extern fn read_csv(path: String, nulls: String, delimiter: String, has_header: Bool) -> DataFrame from "csv.hpp";

let measurements = read_csv("examples/measurements.txt", "", ";", false)
    [select { station = col1, temp = col2 }];

measurements[select {
    min_temp = min(temp),
    avg_temp = mean(temp),
    max_temp = max(temp)
}, by station, order station];
