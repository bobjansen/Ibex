let price = [10.0, 20.0, 30.0];
let qty = [1, 2, 3];
let empty: Series<Float64> = [];

let trades = Table {
    price = price,
    qty = qty
};

print("a table built from two series literals:");
print(trades);

// qty is an Int64 series, so cast it to Float64 to multiply by the price.
print("notional = price * Float64(qty):");
trades[select { notional = price * Float64(qty) }];
