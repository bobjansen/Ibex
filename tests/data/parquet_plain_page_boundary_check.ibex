extern fn read_parquet(path: String) -> DataFrame from "parquet.hpp";

// Regression check for sparse plain-string reads across compressed page
// boundaries. The fixture (see gen_parquet_plain_page_boundary.py) puts a
// page boundary between rows 1023 and 1024 of a SNAPPY-compressed,
// PLAIN-encoded string column with null-free stats. The pushed filter selects
// exactly those two rows, so the payload column decodes through the sparse
// Skip path as one 2-row run straddling the boundary. ByteArray values point
// into the page decompression buffer, which the second page's read reuses: a
// reader that holds row 1023's descriptor across that read prints
// text-002047 (the reused buffer's content) instead of text-001023 — same
// row count, no error, wrong value.
let t = read_parquet("tests/data/parquet_plain_page_boundary_out.parquet");
t[filter id >= 1023 && id <= 1024];
